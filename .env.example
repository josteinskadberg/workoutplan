# Password required to access the app (set in Vercel project settings).
APP_PASSWORD=change-me

# Upstash Redis credentials. After connecting an Upstash Redis store from the
# Vercel Marketplace, run `vercel env pull .env.local` to populate these
# automatically. The legacy KV_REST_API_* names are also accepted as fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
